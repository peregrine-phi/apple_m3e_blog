---
// BaseLayout.astro — Root layout for all pages
import Header from "../widgets/header/Header.astro";
import Footer from "../widgets/footer/Footer.astro";
import Music from "../shared/components/Music.astro";
import MonetCSS from "../shared/components/MonetCSS.astro";
import MDButton from "../shared/components/MDButton.astro";
import MDSnackbar from "../shared/components/MDSnackbar.astro";
import ThemeFlash from "../shared/components/ThemeFlash.astro";
import { ClientRouter } from "astro:transitions";
import Icon from "../shared/components/Icon.astro";
import "../shared/styles/main.css";

import type { NavItem } from "../shared/types";

interface Props {
  title: string;
  description?: string;
  image?: string;
  transparentHeader?: boolean;
  navItems?: NavItem[];
  footerNavItems?: NavItem[];
  footerConnectItems?: NavItem[];
  siteName?: string;
  siteCopyright?: string;
  musicMode?: "local" | "api";
  musicApiEndpoint?: string;
}

const {
  title,
  description,
  image,
  transparentHeader = false,
  navItems,
  footerNavItems,
  footerConnectItems,
  siteName,
  siteCopyright,
  musicMode = "local",
  musicApiEndpoint = "",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light" data-monet="monet--tonalSpot">
  <head>
    <!-- DNS prefetch + preconnect for Google Fonts (eliminates TLS handshake delay) -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts loaded non-render-blocking via media-swap trick.
         font-display=swap in URL handles FOUT: fallback fonts render immediately,
         web fonts swap in once loaded. -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:wght@100..900&family=Noto+Sans+JP:wght@100..900&family=Noto+Sans+SC:wght@100..900&family=Noto+Sans+TC:wght@100..900&family=Noto+Serif+JP:wght@100..900&family=Noto+Serif+SC:wght@100..900&family=Noto+Serif+TC:wght@100..900&display=swap"
      media="print"
      onload="this.media='all';this.onload=null"
    />

    <!-- Restore saved Lang before first paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var navLang = navigator.language
          ? navigator.language.toLowerCase()
          : "";
        var isSimplifiedChinese =
          navLang === "zh" ||
          navLang.startsWith("zh-cn") ||
          navLang.startsWith("zh-sg") ||
          navLang.indexOf("zh-hans") !== -1;
        var l =
          localStorage.getItem("lang") || (isSimplifiedChinese ? "zh" : "en");
        document.documentElement.setAttribute("lang", l);
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {image && <meta property="og:image" content={image} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <!-- Theme color -->
    <meta name="theme-color" content="#65558f" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Monet Dynamic Color CSS (pre-generated at build time) -->
    <MonetCSS />

    <!-- Restore saved Monet scheme before first paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var s = localStorage.getItem("monet-preset");
        if (s) {
          if (s.indexOf("custom-") === 0) {
            document.documentElement.setAttribute("data-monet", s);
            var css = localStorage.getItem("monet-custom-css");
            if (css) {
              var style = document.createElement("style");
              style.id = "monet-custom-inline";
              style.textContent = css;
              document.head.appendChild(style);
            }
          } else {
            var v = localStorage.getItem("monet-variant") || "tonalSpot";
            document.documentElement.setAttribute("data-monet", s + "--" + v);
          }
        }
      })();
    </script>

    <title>{title}</title>

    <!-- Enable Astro SPA Client Router for smooth, white-flash-free cross-page persisted playback -->
    <ClientRouter />

    <!-- Prevent FOUC (Flash of Unstyled Content) with theme -->
    <script is:inline>
      (function () {
        const mode = localStorage.getItem("theme") || "system";
        let resolved = mode;
        if (mode === "system") {
          resolved = window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        document.documentElement.setAttribute("data-theme", resolved);
        document.documentElement.setAttribute("data-theme-mode", mode);
      })();
    </script>
  </head>
  <body>
    <Header
      transparent={transparentHeader}
      navItems={navItems}
      siteName={siteName}
    />
    <main>
      <slot />
    </main>
    <div class="music-player-container">
      <Music mode={musicMode} apiEndpoint={musicApiEndpoint} />
    </div>
    <Footer
      navItems={footerNavItems}
      connectItems={footerConnectItems}
      siteName={siteName}
      copyright={siteCopyright}
    />

    <!-- "Scroll to Top" FAB component -->
    <div class="scroll-to-top-container">
      <MDButton id="scroll-to-top-btn" variant="fab" aria-label="Scroll to top">
        <Icon name="chevron-up" slot="icon" size={24} />
      </MDButton>
    </div>

    <!-- Global MDSnackbar notification container -->
    <MDSnackbar />

    <!-- Theme switch light-switch overlay -->
    <ThemeFlash />

    <style is:global>
      /* Scroll to Top container styling */
      .scroll-to-top-container {
        position: fixed;
        bottom: var(--layout-bottom-gutter);
        right: var(--layout-edge-margin);
        z-index: var(--layout-z-fab); /* Guaranteed to be on top of other floating widgets */
        opacity: 0;
        transform: scale(0) translateY(12px);
        transition:
          opacity var(--blog-motion-duration-normal, 250ms)
            var(--blog-motion-easing-emphasized),
          transform var(--blog-motion-duration-normal, 250ms)
            var(--blog-motion-easing-emphasized);
        pointer-events: none;
        display: flex;
      }

      .scroll-to-top-container.visible {
        opacity: 1;
        transform: scale(1) translateY(0);
        pointer-events: auto;
      }

      /* 音乐播放器容器 — 三态模型 (capsule → strip → card) */
      .music-player-container {
        position: fixed;
        bottom: var(--layout-bottom-gutter);
        left: var(--layout-edge-margin);
        z-index: var(--layout-z-player);
        /* No fixed width: let the player determine its own width per mode */
        max-width: calc(100vw - var(--layout-edge-margin) * 2);
        overflow: visible;
        pointer-events: none; /* Let clicks pass through empty space around player */
        transition:
          transform var(--blog-motion-duration-normal)
            var(--blog-motion-easing-emphasized),
          opacity var(--blog-motion-duration-normal)
            var(--blog-motion-easing-standard);
        display: flex;
      }

      .music-player-container > :global(*) {
        display: block;
      }

      /* Capsule mode: shrink container to auto width to avoid blocking bottom-left clicks */
      .music-player-container:has(.is-capsule) {
        width: auto;
      }

      /* Strip & Card expanded modes: elevate z-index above nav and FAB */
      .music-player-container:has(.is-strip),
      .music-player-container:has(.is-card) {
        z-index: var(--layout-z-player-expanded);
      }

      /* Re-enable pointer events on the actual player element */
      .music-player-container .player-container {
        pointer-events: auto;
      }

      /* Mobile adaptation */
      @media (max-width: 768px) {
        .music-player-container {
          right: auto;
          width: auto;
          max-width: none;
        }

        /* Expanded modes span full bottom width on mobile */
        .music-player-container:has(.is-strip),
        .music-player-container:has(.is-card) {
          right: var(--layout-edge-margin);
        }
      }
    </style>

    <script>
      document.addEventListener("astro:page-load", () => {
        const scrollContainer = document.querySelector(
          ".scroll-to-top-container",
        ) as HTMLElement;
        const scrollBtn = document.getElementById("scroll-to-top-btn");

        if (scrollContainer && scrollBtn) {
          window.addEventListener("scroll", () => {
            if (window.scrollY > 300) {
              scrollContainer.classList.add("visible");
            } else {
              scrollContainer.classList.remove("visible");
            }
          });

          scrollBtn.addEventListener("click", () => {
            window.scrollTo({
              top: 0,
              behavior: "smooth",
            });
          });
        }
      });
    </script>
  </body>
</html>
