---
// M3Showcase.astro — About 页面 M3 组件展示汇总
// Layer: widgets/about
import MonetSwitcher from "../../shared/components/MonetSwitcher.astro";
import Chip from "../../shared/components/Chip.astro";
import Icon from "../../shared/components/Icon.astro";
import PullQuote from "../../shared/components/PullQuote.astro";
import I18n from "../../shared/components/I18n.astro";

interface Props {
  // 无 props，纯展示组件
}
---

<div class="m3-showcase">
  <!-- Monet Dynamic Color -->
  <section class="showcase-section">
    <h3 class="text-title-large">Monet Dynamic Color</h3>
    <div class="showcase-row">
      <MonetSwitcher />
    </div>
  </section>

  <!-- Chips -->
  <section class="showcase-section">
    <h3 class="text-title-large">Chips</h3>
    <div class="showcase-row">
      <Chip variant="assist">
        <Icon slot="icon" name="search" size={18} />
        <span class="i18n-en">Search Posts</span>
        <span class="i18n-zh">搜索文章</span>
      </Chip>
      <Chip variant="filter" selected>
        <span class="i18n-en">Design Systems</span>
        <span class="i18n-zh">设计系统</span>
      </Chip>
      <Chip variant="filter">
        <span class="i18n-en">Frontend</span>
        <span class="i18n-zh">前端开发</span>
      </Chip>
      <Chip variant="filter">
        <span class="i18n-en">Typography</span>
        <span class="i18n-zh">排版艺术</span>
      </Chip>
      <Chip variant="input" closable>astro</Chip>
      <Chip variant="suggestion">Tailwind CSS v4</Chip>
    </div>
  </section>

  <!-- Buttons (M3 State Layer) -->
  <section class="showcase-section">
    <h3 class="text-title-large">Buttons (M3 State Layer)</h3>
    <div class="showcase-row">
      <button class="btn btn-primary">
        <Icon slot="icon" name="plus" size={18} />
        <span class="i18n-en">Filled</span>
        <span class="i18n-zh">填色按钮</span>
      </button>
      <button class="btn btn-secondary">
        <span class="i18n-en">Tonal</span>
        <span class="i18n-zh">色调按钮</span>
      </button>
      <button class="btn btn-ghost">
        <span class="i18n-en">Text</span>
        <span class="i18n-zh">文本按钮</span>
      </button>
      <button class="btn btn-outline">
        <span class="i18n-en">Outlined</span>
        <span class="i18n-zh">描边按钮</span>
      </button>
    </div>
  </section>

  <!-- Text Fields -->
  <section class="showcase-section">
    <h3 class="text-title-large">Text Fields</h3>
    <div class="showcase-row" style="flex-direction: column; gap: var(--blog-space-4); max-width: var(--layout-showcase-max-width);">
      <div class="i18n-en">
        <div class="text-field-demo">
          <label class="tf-label" for="demo-name-en">Your Name</label>
          <input class="tf-input" type="text" id="demo-name-en" name="demo-name-en" placeholder="Enter your full name" />
          <span class="tf-supporting">Enter your full name</span>
        </div>
      </div>
      <div class="i18n-zh">
        <div class="text-field-demo">
          <label class="tf-label" for="demo-name-zh">您的姓名</label>
          <input class="tf-input" type="text" id="demo-name-zh" name="demo-name-zh" placeholder="请在此输入您的真实姓名" />
          <span class="tf-supporting">请在此输入您的真实姓名</span>
        </div>
      </div>
      <div class="i18n-en">
        <div class="text-field-demo">
          <label class="tf-label" for="demo-email-en">Email Address</label>
          <input class="tf-input" type="email" id="demo-email-en" name="demo-email-en" placeholder="you@example.com" />
        </div>
      </div>
      <div class="i18n-zh">
        <div class="text-field-demo">
          <label class="tf-label" for="demo-email-zh">电子邮箱</label>
          <input class="tf-input" type="email" id="demo-email-zh" name="demo-email-zh" placeholder="you@example.com" />
        </div>
      </div>
    </div>
  </section>

  <!-- Surface Containers -->
  <section class="showcase-section">
    <h3 class="text-title-large">Surface Containers (Tonal Elevation)</h3>
    <div class="surface-showcase">
      <div class="surface-swatch" style="background: var(--blog-color-surface-container-lowest);">
        <span>
          <span class="i18n-en">lowest</span>
          <span class="i18n-zh">极低</span>
        </span>
      </div>
      <div class="surface-swatch" style="background: var(--blog-color-surface-container-low);">
        <span>
          <span class="i18n-en">low</span>
          <span class="i18n-zh">低</span>
        </span>
      </div>
      <div class="surface-swatch" style="background: var(--blog-color-surface-container);">
        <span>
          <span class="i18n-en">default</span>
          <span class="i18n-zh">默认</span>
        </span>
      </div>
      <div class="surface-swatch" style="background: var(--blog-color-surface-container-high);">
        <span>
          <span class="i18n-en">high</span>
          <span class="i18n-zh">高</span>
        </span>
      </div>
      <div class="surface-swatch" style="background: var(--blog-color-surface-container-highest);">
        <span>
          <span class="i18n-en">highest</span>
          <span class="i18n-zh">极高</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Pull Quotes -->
  <section class="showcase-section">
    <h3 class="text-title-large">Pull Quotes</h3>
    <div class="showcase-row" style="flex-direction: column; gap: var(--blog-space-4); align-items: stretch; width: 100%;">
      <div class="i18n-en">
        <PullQuote
          quote="A personal blog exploring the intersection of design, technology, and thoughtful living."
          cite="M3E Design philosophy"
          variant="classic"
        />
      </div>
      <div class="i18n-zh">
        <PullQuote
          quote="探讨在网页设计中，苹果克制的优雅与 Material 3 表达的活力之间意想不到的和谐关系。"
          cite="M3E 融合哲学"
          variant="classic"
        />
      </div>
      <div class="i18n-en">
        <PullQuote
          quote="Design is not just what it looks like and feels like. Design is how it works."
          cite="Steve Jobs"
          variant="brutal"
        />
      </div>
      <div class="i18n-zh">
        <PullQuote
          quote="设计不仅仅是外表和感觉。设计是它是如何工作的。"
          cite="史蒂夫·乔布斯"
          variant="brutal"
        />
      </div>
    </div>
  </section>
</div>

<style>
  .m3-showcase {
    display: flex;
    flex-direction: column;
    gap: var(--blog-space-8);
  }

  .showcase-section {
    margin-top: var(--blog-space-8);
  }

  .showcase-section h3 {
    color: var(--blog-color-text-secondary);
    margin-bottom: var(--blog-space-4);
  }

  .showcase-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--blog-space-3);
  }

  /* Surface showcase */
  .surface-showcase {
    display: flex;
    gap: 4px;
  }

  .surface-swatch {
    flex: 1;
    height: 64px;
    border-radius: var(--blog-radius-md);
    border: 1px solid var(--blog-color-border);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: var(--blog-space-2);
  }

  .surface-swatch span {
    font-size: var(--blog-typescale-label-small-size);
    color: var(--blog-color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--blog-typescale-label-small-tracking);
  }

  /* Text field demo (standalone, no JS needed) */
  .text-field-demo {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 100%;
  }

  .tf-label {
    font-size: var(--blog-typescale-label-small-size);
    color: var(--blog-color-text-secondary);
  }

  .tf-input {
    height: var(--blog-space-11, 56px);
    border-radius: var(--blog-radius-xs, 4px);
    border: 1px solid var(--blog-color-outline, #79747E);
    background: var(--blog-color-surface, #FFFBFE);
    color: var(--blog-color-text-primary, #1C1B1F);
    padding: 0 var(--blog-space-4, 16px);
    font-size: var(--blog-typescale-body-large-size, 16px);
    font-family: var(--blog-font-sans, sans-serif);
    transition: border-color 150ms;
  }

  .tf-input:focus {
    outline: none;
    border-color: var(--blog-color-primary, #6750A4);
  }

  .tf-supporting {
    font-size: var(--blog-typescale-label-small-size, 11px);
    color: var(--blog-color-text-tertiary, #49454F);
  }
</style>
