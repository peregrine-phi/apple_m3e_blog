---
// Header.astro — Site header with Liquid Glass navigation bar
// Layer: widgets/header
import ThemeToggle from "../../shared/components/ThemeToggle.astro";
import MonetSwitcher from "../../shared/components/MonetSwitcher.astro";
import LanguageToggle from "../../shared/components/LanguageToggle.astro";
import I18n from "../../shared/components/I18n.astro";
import Icon from "../../shared/components/Icon.astro";
import navigation from "../../shared/config/navigation";
import type { NavItem } from "../../shared/types";

interface Props {
  transparent?: boolean;
  navItems?: NavItem[];
  siteName?: string;
}

const defaultNavItems: NavItem[] = navigation;

const { transparent = false, navItems = defaultNavItems, siteName = "" } = Astro.props;
---

<header class:list={["site-header", { "site-header--transparent": transparent }]}>
  <div class="header-bar">
    <div class="liquid-glass-inner">
      <a href="/" class="site-logo glass-surface-interactive text-headline-small" aria-label="Home">
        <span class="logo-dot" aria-hidden="true">
          <svg class="logo-sprout-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 20h10" />
            <path d="M12 20V12" />
            <path d="M12 12c2-2.67 5-2.67 7 0-2 2.67-5 2.67-7 0Z" />
            <path d="M12 14c-2-2.67-5-2.67-7 0 2 2.67 5 2.67 7 0Z" />
            <path d="M12 12c0-3.33 1.5-6 4-7-2.5 1-4 3.67-4 7Z" />
          </svg>
        </span>
        <I18n tKey="nav.siteName" />
      </a>

      <nav class="site-nav glass-surface-interactive" aria-label="Main navigation">
        {navItems.map((item) => {
          const isCurrent = Astro.url.pathname === item.href || (item.href !== "/" && Astro.url.pathname.startsWith(item.href));
          return (
            <a href={item.href} class="nav-link text-label-large" aria-current={isCurrent ? "page" : undefined} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener" : undefined}>
              {item.labelKey ? <I18n tKey={item.labelKey} /> : item.label}
            </a>
          );
        })}
      </nav>

      <div class="header-actions">
        <div class="hide-mobile" style="display: flex; gap: var(--blog-space-2);">
          <MonetSwitcher />
          <LanguageToggle />
          <ThemeToggle />
        </div>
        <!-- Mobile menu button -->
        <button
          class="btn btn-ghost hide-desktop"
          id="mobile-menu-btn"
          aria-label="Toggle menu"
          type="button"
        >
          <Icon name="menu" size={24} />
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav class="mobile-nav glass-surface hide-desktop" id="mobile-nav" aria-label="Mobile navigation">
      <div class="mobile-menu-actions">
        <MonetSwitcher />
        <LanguageToggle />
        <ThemeToggle />
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileNav = document.getElementById("mobile-nav");

    if (mobileMenuBtn && mobileNav) {
      mobileMenuBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        mobileNav.classList.toggle("open");
      });

      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (
          mobileNav.classList.contains("open") &&
          !mobileNav.contains(target) &&
          !mobileMenuBtn.contains(target)
        ) {
          mobileNav.classList.remove("open");
        }
      });
    }

    const header = document.querySelector(".site-header") as HTMLElement;
    if (header) {
      const onScroll = () => {
        if (window.scrollY > 20) {
          header.classList.add("scrolled");
        } else {
          header.classList.remove("scrolled");
        }
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }
  });
</script>

<style>
  /* Token */
  :root {
    --header-max-width: 1200px;
    --header-height: 54px;
    --header-padding-y: var(--blog-space-3);
    --header-padding-x: var(--blog-space-4);
    --header-scrolled-padding-top: var(--blog-space-1-5, 6px);
  }

  /* Outer Sticky Wrapper */
  .site-header {
    position: sticky;
    top: var(--blog-space-0);
    z-index: var(--layout-z-header);
    padding: var(--header-padding-y) var(--header-padding-x) var(--blog-space-0);
    pointer-events: none;
    transition: padding var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard);
  }

  .header-bar {
    pointer-events: auto;
    max-width: var(--header-max-width);
    margin: var(--blog-space-0) auto;
    background: transparent;
    border: none;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .liquid-glass-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: var(--header-height);
    padding: var(--blog-space-0);
    position: relative;
  }

  /* Glass surfaces */
  .glass-surface-interactive,
  .site-logo,
  .site-nav,
  .header-actions :global(#theme-toggle),
  .header-actions :global(#lang-toggle),
  .header-actions :global(.monet-toggle),
  #mobile-menu-btn,
  .mobile-nav,
  .mobile-menu-actions :global(#theme-toggle),
  .mobile-menu-actions :global(#lang-toggle),
  .mobile-menu-actions :global(.monet-toggle) {
    background: var(--blog-glass-bg);
    backdrop-filter: var(--blog-glass-backdrop);
    -webkit-backdrop-filter: var(--blog-glass-backdrop);
    border: var(--blog-space-px) solid var(--blog-glass-border);
    box-shadow: var(--blog-glass-shadow);
    will-change: transform;
    transition:
      background var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard),
      border-color var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard),
      box-shadow var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard),
      transform var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard),
      translate var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard);
  }

  .glass-surface-interactive:hover,
  .site-logo:hover,
  .site-nav:hover,
  .header-actions :global(#theme-toggle):hover,
  .header-actions :global(#lang-toggle):hover,
  .header-actions :global(.monet-toggle):hover,
  #mobile-menu-btn:hover,
  .mobile-menu-actions :global(#theme-toggle):hover,
  .mobile-menu-actions :global(#lang-toggle):hover,
  .mobile-menu-actions :global(.monet-toggle):hover {
    transform: translateY(-1px);
    background: var(--blog-glass-bg-hover);
    border-color: var(--blog-glass-border-hover);
    box-shadow: var(--blog-glass-shadow-hover);
  }

  /* Brand Capsule */
  .site-logo {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    height: var(--pill-h-md, 40px);
    border-radius: var(--blog-radius-full);
    padding: var(--blog-space-1) var(--blog-space-4) var(--blog-space-1) var(--nav-pill-inner-gap, 12px);
    text-decoration: none;
    gap: var(--blog-space-2);
  }

  .logo-dot {
    width: var(--nav-pill-tab-height, 32px);
    height: var(--nav-pill-tab-height, 32px);
    border-radius: var(--blog-radius-full);
    background: var(--blog-color-primary-container);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition:
      transform var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard),
      background-color var(--blog-motion-duration-fast, 150ms) var(--blog-motion-easing-standard);
  }

  .logo-sprout-svg {
    width: 20px;
    height: 20px;
    color: var(--blog-color-on-primary-container);
    flex-shrink: 0;
  }

  .site-logo:hover .logo-dot {
    transform: scale(1.05);
  }

  /* Center Nav */
  .site-nav {
    justify-self: center;
    display: flex;
    align-items: center;
    height: var(--nav-pill-height, 48px);
    border-radius: var(--blog-radius-full);
    padding: var(--nav-pill-inner-gap, 4px);
    gap: var(--nav-pill-inner-gap, 4px);
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    height: var(--nav-pill-tab-height, 32px);
    padding: var(--blog-space-0) var(--blog-space-4);
    font-family: var(--blog-font-sans, 'Inter', sans-serif);
    font-size: var(--blog-typescale-label-large-size, 12px);
    font-weight: var(--blog-font-weight-medium, 500);
    color: var(--blog-color-text-secondary);
    text-decoration: none;
    border-radius: var(--blog-radius-full);
    transition:
      color var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard),
      background-color var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-standard);
  }

  .nav-link:hover,
  .nav-link[aria-current="page"] {
    background-color: var(--blog-color-surface-variant);
    color: var(--blog-color-primary);
    font-weight: var(--blog-font-weight-semibold, 600);
  }

  /* Right Actions */
  .header-actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--blog-space-2);
  }

  .header-actions :global(#theme-toggle),
  .header-actions :global(.monet-toggle) {
    width: var(--pill-h-md, 40px);
    height: var(--pill-h-md, 40px);
    border-radius: var(--blog-radius-full);
    padding: var(--blog-space-0);
    cursor: pointer;
    overflow: visible;
  }

  .header-actions :global(#lang-toggle) {
    min-width: var(--pill-h-md, 40px);
    height: var(--pill-h-md, 40px);
    border-radius: var(--blog-radius-full);
    padding-inline: var(--blog-space-3);
    cursor: pointer;
    overflow: visible;
  }

  #mobile-menu-btn {
    width: var(--pill-h-md, 40px);
    height: var(--pill-h-md, 40px);
    border-radius: var(--blog-radius-full);
    padding: var(--blog-space-0);
    cursor: pointer;
    overflow: visible;
  }

  /* Mobile menu */
  .mobile-nav {
    display: none;
    flex-direction: column;
    margin-top: var(--blog-space-3);
    padding: var(--blog-space-2);
    border-radius: var(--blog-radius-container, 16px);
    pointer-events: auto;
  }

  .mobile-nav.open {
    display: flex;
    animation: slideDown var(--blog-motion-duration-normal, 250ms) var(--blog-motion-easing-emphasized);
  }

  .mobile-menu-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--blog-space-4);
    padding: var(--blog-space-0);
    width: 100%;
  }

  .mobile-menu-actions :global(#theme-toggle),
  .mobile-menu-actions :global(.monet-toggle) {
    width: var(--pill-h-md, 40px);
    height: var(--pill-h-md, 40px);
    border-radius: var(--blog-radius-full);
    padding: var(--blog-space-0);
    cursor: pointer;
  }

  .mobile-menu-actions :global(#lang-toggle) {
    min-width: var(--pill-h-md, 40px);
    height: var(--pill-h-md, 40px);
    border-radius: var(--blog-radius-full);
    padding-inline: var(--blog-space-3);
    cursor: pointer;
  }

  @keyframes slideDown {
    from {
      opacity: var(--blog-space-0);
      transform: translateY(calc(var(--blog-space-2) * -1));
    }
    to {
      opacity: 1;
      transform: translateY(var(--blog-space-0));
    }
  }

  /* Scrolled state */
  .site-header.scrolled {
    padding-top: var(--header-scrolled-padding-top);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .site-header {
      padding: var(--blog-space-3) var(--blog-space-4) var(--blog-space-0);
    }

    .liquid-glass-inner {
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
    }

    .site-logo {
      position: absolute;
      left: 50%;
      translate: -50% 0;
      transform: none;
      justify-self: auto;
      white-space: nowrap;
      height: var(--pill-h-lg, 44px);
      padding: var(--blog-space-1) var(--blog-space-4) var(--blog-space-1) var(--nav-pill-inner-gap, 12px);
      font-size: var(--blog-typescale-title-medium-size) !important;
    }

    .site-logo:hover {
      translate: -50% -1px;
      transform: none;
    }

    .logo-dot {
      width: var(--blog-space-9, 36px);
      height: var(--blog-space-9, 36px);
    }

    .site-nav {
      position: fixed;
      bottom: var(--layout-bottom-gutter, 24px);
      left: 50%;
      translate: -50% 0;
      transform: none;
      z-index: var(--layout-z-bottom-bar);
      justify-self: auto;
    }

    .site-nav:hover {
      translate: -50% -1px;
      transform: none;
    }

    .header-actions {
      position: absolute;
      right: 0;
      justify-self: auto;
    }

    .mobile-menu-actions {
      flex-direction: row;
    }
  }
</style>
