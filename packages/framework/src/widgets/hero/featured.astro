---
// HeroFeatured.astro — Hero 精选文章区块（Editorial 风格）
// Layer: widgets/hero
import type { CollectionEntry } from "astro:content";
import MDBadge from "../../shared/components/MDBadge.astro";
import MDButton from "../../shared/components/MDButton.astro";
import I18n from "../../shared/components/I18n.astro";
import Icon from "../../shared/components/Icon.astro";

interface Props {
  featuredPosts: CollectionEntry<"blog">[];
}

const { featuredPosts } = Astro.props;
const leadStory = featuredPosts[0];
const sideStories = featuredPosts.slice(1, 3);
const hasHero = leadStory != null;
---

<!-- Hero Editorial Section -->
{
  hasHero ? (
    <section class="hero-editorial">
      <div class="container-wide hero-editorial-grid">
        <!-- Lead Story -->
        <article class="hero-lead">
          <div class="hero-lead-content">
            <p class="hero-kicker text-kicker" style="display: flex; align-items: center; gap: var(--blog-space-2);">
              <MDBadge variant="primary" type="dot" style="flex-shrink: 0;" />
              {leadStory.data.tags?.[0] ?? <I18n tKey="home.featured" />}
            </p>
            <h1 class="hero-headline text-display-large">
              <a href={`/blog/${leadStory.id.replace(/\.mdx?$/, "")}`}>
                {leadStory.data.title}
              </a>
            </h1>
            <p class="hero-deck text-deck">
              {leadStory.data.description}
            </p>
            <MDButton href={`/blog/${leadStory.id.replace(/\.mdx?$/, "")}`} variant="outlined" class="hero-cta">
              <I18n tKey="home.read" />
              <Icon slot="icon-trailing" name="arrow-right" size={16} />
            </MDButton>
          </div>
        </article>

        <!-- Side Stories -->
        {
          sideStories.length > 0 && (
            <div class="hero-side">
              {sideStories.map((story) => (
                <article class="hero-side-card">
                  <p class="hero-side-kicker text-kicker">
                    {story.data.tags?.[0] ?? <I18n tKey="home.featured" />}
                  </p>
                  <h2 class="hero-side-title text-headline-medium">
                    <a href={`/blog/${story.id.replace(/\.mdx?$/, "")}`}>
                      {story.data.title}
                    </a>
                  </h2>
                  <p class="hero-side-desc text-body-medium text-secondary">
                    {story.data.description}
                  </p>
                </article>
              ))}
            </div>
          )
        }
      </div>

      <!-- Decorative gradient blob -->
      <div class="hero-editorial-blob" aria-hidden="true"></div>
    </section>
  ) : (
    /* Fallback: text-only Hero when no featured posts */
    <section class="hero-fallback">
      <div class="container-narrow hero-fallback-content">
        <p class="text-kicker" style="display: flex; align-items: center; gap: var(--blog-space-2);">
          <MDBadge variant="primary" type="dot" style="flex-shrink: 0;" />
          <I18n tKey="home.welcome" vars={{ siteName: "M3E" }} />
        </p>
        <h1 class="text-display-large">
          <I18n tKey="home.designMeets" />
          <span class="hero-accent"><I18n tKey="home.expression" /></span>
        </h1>
        <p class="text-deck">
          <I18n tKey="home.fallbackDeck" />
        </p>
        <div class="hero-fallback-actions">
          <MDButton href="/blog" variant="filled"><I18n tKey="home.readBlog" /></MDButton>
          <MDButton href="/about" variant="text"><I18n tKey="home.aboutMe" /></MDButton>
        </div>
      </div>
      <div class="hero-fallback-blob" aria-hidden="true"></div>
    </section>
  )
}
<style>
  /* ── Editorial Hero ── */
  .hero-editorial {
    position: relative;
    padding-block: clamp(80px, 12vh, 160px) clamp(48px, 8vh, 80px);
    overflow: hidden;
  }

  .hero-editorial-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: start;
  }

  .hero-lead {
    display: flex;
    flex-direction: column;
  }

  .hero-lead-content {
    display: flex;
    flex-direction: column;
    gap: var(--blog-space-4);
    padding-block: var(--blog-space-6);
  }

  .hero-kicker {
    margin-bottom: 0;
  }

  .hero-headline {
    margin: 0;
  }

  .hero-headline a {
    color: var(--blog-color-text-primary);
    text-decoration: none;
    transition: color var(--blog-motion-duration-fast) var(--blog-motion-easing-standard);
  }

  .hero-headline a:hover {
    color: var(--blog-color-primary);
  }

  .hero-deck {
    max-width: 48ch;
  }

  .hero-cta {
    margin-top: var(--blog-space-2);
    align-self: flex-start;
  }

  .hero-side {
    display: flex;
    flex-direction: column;
    gap: var(--blog-space-6);
    padding-top: var(--blog-space-6);
  }

  .hero-side-card {
    padding-bottom: var(--blog-space-6);
    border-bottom: 1px solid var(--blog-color-divider);
  }

  .hero-side-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .hero-side-kicker {
    margin-bottom: var(--blog-space-2);
  }

  .hero-side-title {
    margin: 0 0 var(--blog-space-2) 0;
  }

  .hero-side-title a {
    color: var(--blog-color-text-primary);
    text-decoration: none;
    transition: color var(--blog-motion-duration-fast) var(--blog-motion-easing-standard);
  }

  .hero-side-title a:hover {
    color: var(--blog-color-primary);
  }

  .hero-side-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  /* Editorial blob */
  .hero-editorial-blob {
    position: absolute;
    top: -30%;
    right: -15%;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--blog-color-primary) 6%, transparent),
      color-mix(in srgb, var(--blog-color-tertiary) 3%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }

  [data-theme="dark"] .hero-editorial-blob {
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--blog-color-primary) 8%, transparent),
      color-mix(in srgb, var(--blog-color-tertiary) 4%, transparent),
      transparent 70%
    );
  }

  /* ── Fallback Hero ── */
  .hero-fallback {
    position: relative;
    padding-block: clamp(64px, 12vh, 160px);
    overflow: hidden;
  }

  .hero-fallback-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--blog-space-4);
  }

  .hero-accent {
    background: linear-gradient(
      135deg,
      var(--blog-color-primary),
      var(--blog-color-tertiary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-fallback-actions {
    display: flex;
    gap: var(--blog-space-3);
    margin-top: var(--blog-space-2);
  }

  .hero-fallback-blob {
    position: absolute;
    top: -40%;
    right: -20%;
    width: 800px;
    height: 800px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--blog-color-primary) 8%, transparent),
      color-mix(in srgb, var(--blog-color-tertiary) 4%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }

  [data-theme="dark"] .hero-fallback-blob {
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--blog-color-primary) 10%, transparent),
      color-mix(in srgb, var(--blog-color-tertiary) 5%, transparent),
      transparent 70%
    );
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-editorial-grid {
      grid-template-columns: 1fr;
    }

    .hero-side {
      padding-top: 0;
      flex-direction: row;
      overflow-x: auto;
      gap: var(--blog-space-4);
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      padding-bottom: var(--blog-space-4);
    }

    .hero-side-card {
      min-width: 260px;
      scroll-snap-align: start;
      padding-bottom: 0;
      border-bottom: none;
      padding-right: var(--blog-space-4);
      border-right: 1px solid var(--blog-color-divider);
    }

    .hero-side-card:last-child {
      padding-right: 0;
      border-right: none;
    }
  }
</style>
