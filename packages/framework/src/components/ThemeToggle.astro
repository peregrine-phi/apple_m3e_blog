---
// ThemeToggle.astro — Light/Dark mode toggle
import Icon from "./Icon.astro";
---

<button
  id="theme-toggle"
  class="btn btn-ghost"
  aria-label="Toggle theme"
  type="button"
>
  <!-- Sun icon (visible in light mode) -->
  <Icon
    name="sun"
    size={20}
    class="theme-icon theme-icon-light"
  />
  <!-- Moon icon (visible in dark mode) -->
  <Icon
    name="moon"
    size={20}
    class="theme-icon theme-icon-dark"
  />
  <!-- System / Monitor icon (visible in system mode) -->
  <Icon
    name="system"
    size={20}
    class="theme-icon theme-icon-system"
  />
</button>

<style>
  :global(.theme-icon) {
    display: none !important;
  }

  :global(html[data-theme-mode="light"] .theme-icon-light) {
    display: block !important;
  }

  :global(html[data-theme-mode="dark"] .theme-icon-dark) {
    display: block !important;
  }

  :global(html:not([data-theme-mode="light"]):not([data-theme-mode="dark"]) .theme-icon-system),
  :global(html[data-theme-mode="system"] .theme-icon-system) {
    display: block !important;
  }

  #theme-toggle {
    width: var(--toggle-size, 40px);
    height: var(--toggle-size, 40px);
    padding: 0;
    border-radius: var(--blog-radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

<script>
  function getThemeMode() {
    return localStorage.getItem("theme") || "system";
  }

  function setThemeMode(mode: string) {
    localStorage.setItem("theme", mode);
    
    let resolvedTheme = mode;
    if (mode === "system") {
      resolvedTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    
    document.documentElement.setAttribute("data-theme", resolvedTheme);
    document.documentElement.setAttribute("data-theme-mode", mode);
  }

  // Apply theme mode on load to prevent flash
  const initialMode = getThemeMode();
  setThemeMode(initialMode);

  function initThemeToggle() {
    const btns = document.querySelectorAll("#theme-toggle");
    btns.forEach((btn) => {
      const handleToggle = () => {
        const currentMode = getThemeMode();
        let nextMode = "system";
        if (currentMode === "system") {
          nextMode = "light";
        } else if (currentMode === "light") {
          nextMode = "dark";
        } else if (currentMode === "dark") {
          nextMode = "system";
        }
        setThemeMode(nextMode);
      };

      // Prevent duplicate event handlers on swaps
      btn.removeEventListener("click", (btn as any)._themeHandler);
      btn.addEventListener("click", handleToggle);
      (btn as any)._themeHandler = handleToggle;
    });
  }

  initThemeToggle();

  // Listen to system prefers-color-scheme media query changes
  const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
  try {
    mediaQuery.addEventListener("change", () => {
      if (getThemeMode() === "system") {
        setThemeMode("system");
      }
    });
  } catch (e) {
    // Fallback for older browsers
    mediaQuery.addListener(() => {
      if (getThemeMode() === "system") {
        setThemeMode("system");
      }
    });
  }

  // Support Astro view transitions / swaps
  document.addEventListener("astro:after-swap", () => {
    setThemeMode(getThemeMode());
    initThemeToggle();
  });
</script>
