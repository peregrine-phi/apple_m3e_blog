---
// Backlinks.astro — Displays incoming links (backlinks) to the current page
import I18n from "./I18n.astro";

interface BacklinkItem {
  slug: string;
  title: string;
  description: string;
  growthStage: 'seedling' | 'budding' | 'evergreen';
}

interface Props {
  backlinks?: BacklinkItem[];
}

const { backlinks = [] } = Astro.props;

const hasBacklinks = backlinks.length > 0;

// Mapping stages to emojis
const STAGE_MAP = {
  seedling: "🌱",
  budding: "🌿",
  evergreen: "🌳",
};
---

{
  hasBacklinks && (
    <div class="backlinks-section">
      <h3 class="backlinks-title text-title-large">
        <span class="backlinks-title-dot"></span>
        <I18n tKey="post.connections" />
      </h3>
      <div class="backlinks-grid">
        {backlinks.map((link) => {
          const emoji = STAGE_MAP[link.growthStage || "seedling"];
          return (
            <article class="backlink-card">
              <a href={`/blog/${link.slug}`} class="backlink-link">
                <div class="backlink-header">
                  <span class={`backlink-stage-badge backlink-stage--${link.growthStage}`} title={`Growth stage: ${link.growthStage}`}>
                    <span class="badge-emoji">{emoji}</span>
                    <span class="badge-text"><I18n tKey={`stage.${link.growthStage}` as any} /></span>
                  </span>
                </div>
                <h4 class="backlink-card-title text-title-medium">{link.title}</h4>
                <p class="backlink-card-desc text-body-medium text-secondary">{link.description}</p>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  )
}


