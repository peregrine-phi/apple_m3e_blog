---
// src/components/LanguageToggle.astro — Language switcher button (EN/中文)
import Icon from "./Icon.astro";
---

<button
  id="lang-toggle"
  class="btn btn-ghost"
  aria-label="Toggle language"
  type="button"
>
  <!-- Globe / Translation Icon -->
  <Icon
    name="globe"
    size={20}
    class="lang-icon"
  />
  <span class="lang-text text-label-large">
    <span class="i18n-en">EN</span>
    <span class="i18n-zh">中</span>
  </span>
</button>

<style>
  #lang-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--blog-space-1, 4px);
    height: 40px;
    padding-inline: var(--blog-space-2, 8px);
    border-radius: var(--blog-radius-full);
    color: var(--blog-color-text-secondary);
    transition: color var(--blog-motion-duration-fast), background-color var(--blog-motion-duration-fast);
  }

  #lang-toggle:hover {
    color: var(--blog-color-text-primary);
    background-color: var(--blog-color-surface-variant);
  }

  .lang-icon {
    flex-shrink: 0;
  }

  .lang-text {
    font-size: var(--blog-typescale-label-large-size);
    font-weight: var(--blog-font-weight-semibold);
    display: inline-flex;
    justify-content: center;
    width: var(--toggle-text-width, 20px);
    text-align: center;
  }
</style>

<script>
  function getLang() {
    return document.documentElement.getAttribute("lang") || "en";
  }

  function setLang(lang: string) {
    document.documentElement.setAttribute("lang", lang);
    localStorage.setItem("lang", lang);
    // Dispatch a custom event so other page elements can update dynamically if needed
    window.dispatchEvent(new CustomEvent("lang-change", { detail: { lang } }));
  }

  function initLangToggle() {
    const btn = document.getElementById("lang-toggle");
    if (!btn) return;

    btn.addEventListener("click", () => {
      const current = getLang();
      const next = current === "zh" ? "en" : "zh";
      setLang(next);
    });
  }

  initLangToggle();
  // Support Astro view transitions / swaps
  document.addEventListener("astro:after-swap", initLangToggle);
</script>
