---
// HomePage.astro — Home page template (Apple News editorial style)
// Layer: packages/framework (reusable across apps)
import type { CollectionEntry } from "astro:content";
import HeroLayout from "../layouts/HeroLayout.astro";
import BlogCard from "../components/BlogCard.astro";
import MDButton from "../components/MDButton.astro";
import MDBadge from "../components/MDBadge.astro";
import I18n from "../components/I18n.astro";
import Icon from "../components/Icon.astro";

interface Props {
  siteName: string;
  siteTagline: string;
  siteDescription: string;
  siteCopyright: string;
  musicMode?: "api" | "local";
  musicApiEndpoint: string;
  featuredPosts: CollectionEntry<"blog">[];
  recentPosts: CollectionEntry<"blog">[];
}

const {
  siteName,
  siteTagline,
  siteDescription,
  siteCopyright,
  musicMode,
  musicApiEndpoint,
  featuredPosts,
  recentPosts,
} = Astro.props;

const leadStory = featuredPosts[0];
const sideStories = featuredPosts.slice(1, 3);
const hasHero = leadStory != null;
---

<HeroLayout
  title={`${siteName} — ${siteTagline}`}
  description={siteDescription}
  siteName={siteName}
  siteCopyright={siteCopyright}
  musicMode={musicMode}
  musicApiEndpoint={musicApiEndpoint}
>
  <!-- Hero slot: the editorial hero section -->
  <div slot="hero">
  <!-- Hero Section — Apple News editorial layout -->
  {
    hasHero ? (
      <section class="hero-editorial">
        <div class="container-wide hero-editorial-grid">
          <!-- Lead Story — dominates 2/3 width -->
          <article class="hero-lead">
            <div class="hero-lead-content">
              <p class="hero-kicker text-kicker" style="display: flex; align-items: center; gap: var(--blog-space-2);">
                <MDBadge variant="primary" type="dot" style="flex-shrink: 0;" />
                {leadStory.data.tags?.[0] ?? <I18n tKey="home.featured" />}
              </p>
              <h1 class="hero-headline text-display-large">
                <a href={`/blog/${leadStory.id.replace(/\.mdx?$/, "")}`}>
                  {leadStory.data.title}
                </a>
              </h1>
              <p class="hero-deck text-deck">
                {leadStory.data.description}
              </p>
              <MDButton href={`/blog/${leadStory.id.replace(/\.mdx?$/, "")}`} variant="outlined" class="hero-cta">
                <I18n tKey="home.read" />
                <Icon slot="icon-trailing" name="arrow-right" size={16} />
              </MDButton>
            </div>
          </article>

          <!-- Side Stories — stacked in 1/3 column -->
          {
            sideStories.length > 0 && (
              <div class="hero-side">
                {sideStories.map((story) => (
                  <article class="hero-side-card">
                    <p class="hero-side-kicker text-kicker">
                      {story.data.tags?.[0] ?? <I18n tKey="home.featured" />}
                    </p>
                    <h2 class="hero-side-title text-headline-medium">
                      <a href={`/blog/${story.id.replace(/\.mdx?$/, "")}`}>
                        {story.data.title}
                      </a>
                    </h2>
                    <p class="hero-side-desc text-body-medium text-secondary">
                      {story.data.description}
                    </p>
                  </article>
                ))}
              </div>
            )
          }
        </div>

        <!-- Decorative gradient — editorial mood -->
        <div class="hero-editorial-blob" aria-hidden="true"></div>
      </section>
    ) : (
      /* Fallback: text-only Hero when no featured posts */
      <section class="hero-fallback">
        <div class="container-narrow hero-fallback-content">
          <p class="text-kicker" style="display: flex; align-items: center; gap: var(--blog-space-2);">
            <MDBadge variant="primary" type="dot" style="flex-shrink: 0;" />
            <I18n tKey="home.welcome" vars={{ siteName }} />
          </p>
          <h1 class="text-display-large">
            <I18n tKey="home.designMeets" />
            <span class="hero-accent"><I18n tKey="home.expression" /></span>
          </h1>
          <p class="text-deck">
            <I18n tKey="home.fallbackDeck" />
          </p>
          <div class="hero-fallback-actions">
            <MDButton href="/blog" variant="filled"><I18n tKey="home.readBlog" /></MDButton>
            <MDButton href="/about" variant="text"><I18n tKey="home.aboutMe" /></MDButton>
          </div>
        </div>
        <div class="hero-fallback-blob" aria-hidden="true"></div>
      </section>
    )
  }

  </div>

  <!-- Recent Posts -->
  <section class="section-recent">
    <div class="container-wide">
      <div class="section-header">
        <div>
          <p class="text-kicker" style="display: flex; align-items: center; gap: var(--blog-space-2);">
            <MDBadge variant="primary" type="dot" style="flex-shrink: 0;" />
            <I18n tKey="home.latest" />
          </p>
          <h2 class="text-headline-large"><I18n tKey="home.recent" /></h2>
        </div>
        <MDButton href="/blog" variant="text">
          <I18n tKey="home.viewAll" />
          <Icon slot="icon-trailing" name="arrow-right" size={16} />
        </MDButton>
      </div>
      <div class="blog-grid">
        {recentPosts.map((post) => <BlogCard post={post} />)}
      </div>
    </div>
  </section>
</HeroLayout>
