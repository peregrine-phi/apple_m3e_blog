---
// HomePage.astro — 首页瘦入口（委托给 widgets）
// Layer: packages/framework/pages (page assembly layer)
import HeroLayout from "../layouts/HeroLayout.astro";
import HeroFeatured from "../widgets/hero/featured.astro";
import RecentPosts from "../widgets/recent-posts/RecentPosts.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  siteName: string;
  siteTagline: string;
  siteDescription: string;
  siteCopyright: string;
  musicMode?: "api" | "local";
  musicApiEndpoint: string;
  featuredPosts: CollectionEntry<"blog">[];
  recentPosts: CollectionEntry<"blog">[];
}

const {
  siteName,
  siteTagline,
  siteDescription,
  siteCopyright,
  musicMode,
  musicApiEndpoint,
  featuredPosts,
  recentPosts,
} = Astro.props;
---

<HeroLayout
  title={`${siteName} — ${siteTagline}`}
  description={siteDescription}
  siteName={siteName}
  siteCopyright={siteCopyright}
  musicMode={musicMode}
  musicApiEndpoint={musicApiEndpoint}
>
  <HeroFeatured slot="hero" featuredPosts={featuredPosts} />
  <RecentPosts posts={recentPosts} />
</HeroLayout>
