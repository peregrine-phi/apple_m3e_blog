---
// AboutPage.astro — About 页面瘦入口（委托给 widgets）
// Layer: packages/framework/pages (page assembly layer)
import type { AstroComponentFactory } from "astro";
import PageLayout from "../layouts/PageLayout.astro";
import AboutBio from "../widgets/about/bio.astro";
import M3Showcase from "../widgets/about/m3-showcase.astro";
import I18n from "../shared/components/I18n.astro";

interface Props {
  siteName: string;
  siteDescription: string;
  siteCopyright: string;
  musicMode?: "api" | "local";
  musicApiEndpoint: string;
  enContent: AstroComponentFactory | null;
  zhContent: AstroComponentFactory | null;
}

const {
  siteName,
  siteDescription,
  siteCopyright,
  musicMode,
  musicApiEndpoint,
  enContent: EnContent,
  zhContent: ZhContent,
} = Astro.props;
---

<PageLayout 
  title={`About — ${siteName}`} 
  description={`About the author behind ${siteName} blog.`}
  siteName={siteName}
  siteCopyright={siteCopyright}
  musicMode={musicMode}
  musicApiEndpoint={musicApiEndpoint}
>
  <header class="page-header">
    <h1 class="text-display-small"><I18n tKey="about.heading" /></h1>
  </header>

  <div class="about-content">
    <AboutBio enContent={EnContent} zhContent={ZhContent} />
    <M3Showcase />
  </div>
</PageLayout>

<style>
  .page-header {
    margin-bottom: var(--blog-space-10);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--blog-space-8);
  }
</style>
