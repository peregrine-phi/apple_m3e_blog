---
// HeroLayout.astro (Layer 2)
// Extends BaseLayout with a hero section above foldable content.
// The hero slot is full-bleed; content slot is narrow-centered.
// Use for: home page, landing pages, featured article pages.

import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  transparentHeader?: boolean;
}

const { title, description, transparentHeader = true } = Astro.props;
---

<BaseLayout title={title} description={description} transparentHeader={transparentHeader}>
  <section class="hero-layout-hero">
    <slot name="hero" />
  </section>
  <main class="hero-layout-content">
    <slot />
  </main>
</BaseLayout>

<style>
  .hero-layout-hero {
    position: relative;
    overflow: hidden;
  }

  .hero-layout-content {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--blog-space-page-inline);
    padding-block-end: var(--blog-space-16);
  }
</style>
