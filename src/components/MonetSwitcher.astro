---
// MonetSwitcher.astro — Compact header Monet dynamic color switcher
// CSS is pre-generated in MonetCSS.astro; this is the interactive UI only.
import { generateSchemeCSS, MONET_PRESETS } from "../utils/monet";
import { monetConfig } from "../config/monet.config.js";
const defaultSeed = monetConfig.defaultSeed;
---

<monet-switcher>
  <button class="monet-toggle btn btn-ghost" type="button" aria-label="Change color scheme" aria-expanded="false">
    <span class="monet-toggle-dot"></span>
  </button>

  <div class="monet-dropdown" hidden>
    <div class="monet-presets-list">
      {MONET_PRESETS.map((preset) => {
        const displayName = preset.name.split("-").map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(" ");
        return (
          <button
            class="monet-preset-row" 
            type="button"
            data-name={preset.name.replace(/\s+/g, "-").toLowerCase()}
            data-label={displayName}
            aria-label={`Select ${displayName} theme`}
          >
            <span class="monet-preset-name">{displayName}</span>
            <div class="monet-capsules">
              <span class="monet-capsule" style={`background-color: ${preset.seed}`}></span>
              <span class="monet-capsule" style={`background-color: ${preset.secondary || 'var(--blog-color-secondary)'}`}></span>
            </div>
          </button>
        );
      })}
      
      <button 
        class="monet-preset-row monet-custom-row" 
        type="button"
        data-name="custom"
        data-label="Custom Color"
        aria-label="Select custom color"
      >
        <span class="monet-preset-name">Custom</span>
        <div class="monet-capsules">
          <span class="monet-capsule monet-custom-capsule-1" style={`background-color: var(--custom-color-1, ${defaultSeed})`}></span>
          <span class="monet-capsule monet-custom-capsule-2" style={`background-color: var(--custom-color-2, color-mix(in srgb, var(--custom-color-1, ${defaultSeed}) 60%, var(--blog-color-tertiary)))`}></span>
          <input type="color" class="monet-custom-picker" value={defaultSeed} aria-label="Choose custom color" />
        </div>
      </button>
    </div>
  </div>
</monet-switcher>

<style>
  monet-switcher {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .monet-toggle {
    width: var(--toggle-size, 24px);
    height: var(--toggle-size, 24px);
    padding: 0;
    border-radius: var(--blog-radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blog-color-text-secondary);
    transition: background-color var(--blog-motion-duration-fast) var(--blog-motion-easing-standard);
  }

  .monet-toggle:hover {
    background-color: var(--blog-color-surface-variant);
  }

  .monet-toggle-dot {
    width: var(--monet-icon-size, 10px);
    height: var(--monet-icon-size, 10px);
    border-radius: var(--blog-radius-full);
    background-color: var(--blog-color-primary);
    box-shadow: 0 0 0 2px var(--blog-color-background), 0 0 0 3.5px var(--blog-color-primary);
    transition: transform var(--blog-motion-duration-fast) var(--blog-motion-easing-standard), 
                background-color var(--blog-motion-duration-normal) var(--blog-motion-easing-standard),
                box-shadow var(--blog-motion-duration-normal) var(--blog-motion-easing-standard);
  }

  .monet-toggle:hover .monet-toggle-dot {
    transform: scale(1.15);
  }

  .monet-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    z-index: 200;
    width: var(--monet-dropdown-width, 90px);
    min-width: auto;
    padding: 5px;
    background: var(--blog-color-surface-container-high, #ffffff);
    border: 1px solid var(--blog-color-outline-variant, rgba(0, 0, 0, 0.08));
    border-radius: var(--blog-radius-sm, 10px);
    box-shadow: var(--blog-shadow-dropdown, 0 6px 16px rgba(0, 0, 0, 0.05));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    animation: slideIn 200ms var(--blog-motion-easing-decelerate);
  }

  [data-theme="dark"] .monet-dropdown {
    background: var(--blog-color-surface-container-high, #1e1e24);
    border-color: rgba(255, 255, 255, 0.08);
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .monet-dropdown[hidden] {
    display: none;
  }

  .monet-presets-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .monet-preset-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 4px 6px;
    background: transparent;
    border: none;
    outline: none;
    cursor: pointer;
    border-radius: 6px;
    transition: background-color 150ms var(--blog-motion-easing-standard);
  }

  .monet-preset-row:hover {
    background-color: var(--blog-color-surface-variant, rgba(0, 0, 0, 0.04));
  }

  [data-theme="dark"] .monet-preset-row:hover {
    background-color: rgba(255, 255, 255, 0.04);
  }

  .monet-preset-row[data-active] {
    background-color: var(--blog-color-primary-container, rgba(59, 92, 246, 0.12));
  }

  .monet-preset-row[data-active] .monet-preset-name {
    font-weight: var(--blog-font-weight-semibold, 600);
    color: var(--blog-color-on-primary-container, var(--blog-color-primary));
  }

  .monet-preset-name {
    font-family: var(--blog-font-sans);
    font-size: var(--blog-typescale-label-small-size, 11px);
    font-weight: var(--blog-font-weight-regular, 400);
    color: var(--blog-color-text-primary, #1c1b1f);
    text-align: left;
    transition: color 150ms, font-weight 150ms;
  }

  [data-theme="dark"] .monet-preset-name {
    color: var(--blog-color-text-primary, #e6e1e5);
  }

  .monet-capsules {
    display: flex;
    gap: 2.5px;
    position: relative;
    align-items: center;
  }

  .monet-capsule {
    width: 6px;
    height: 14px;
    border-radius: 9999px;
    display: inline-block;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  /* Custom Color picker row */
  .monet-custom-row {
    position: relative;
  }

  .monet-custom-picker {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
    border: none;
    padding: 0;
    z-index: 10;
  }
</style>

<script>
  import { generateSchemeCSS, MONET_PRESETS } from "../utils/monet";

  class MonetSwitcher extends HTMLElement {
    private preset = "monet";
    private variant = "tonalSpot";
    private dropdown!: HTMLElement;
    private toggleBtn!: HTMLElement;

    connectedCallback() {
      this.dropdown = this.querySelector(".monet-dropdown")!;
      this.toggleBtn = this.querySelector(".monet-toggle")!;

      this.preset = localStorage.getItem("monet-preset") || "monet";
      this.variant = localStorage.getItem("monet-variant") || "tonalSpot";

      // Restore saved scheme
      if (this.preset) {
        if (this.preset.startsWith("custom-")) {
          const hex = localStorage.getItem("monet-custom-hex");
          if (hex) {
            const key = `custom-${hex.replace("#", "")}-${this.variant}`;
            const { light, dark } = generateSchemeCSS(hex, this.variant);
            const cssStr = light.replace(
              /\[data-monet="[^"]*"\]/,
              `[data-monet="${key}"]`
            ) +
              "\n" +
              dark.replace(
                /\[data-theme="dark"\]\[data-monet="[^"]*"\]/,
                `[data-theme="dark"][data-monet="${key}"]`
              );
            this.inject(cssStr);
            document.documentElement.setAttribute("data-monet", key);
            this.preset = key;
            localStorage.setItem("monet-preset", key);
            localStorage.setItem("monet-custom-css", cssStr);
            this.updateActiveUI("custom", "Custom Color", hex);
          }
        } else {
          const name = this.preset.split("--")[0];
          this.preset = name;
          this.apply(name, this.variant);
          const presetObj = MONET_PRESETS.find(p => p.name.replace(/\s+/g, "-").toLowerCase() === name);
          const displayName = presetObj 
            ? presetObj.name.split("-").map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(" ")
            : "Theme";
          this.updateActiveUI(name, displayName);
        }
      }

      // Toggle dropdown
      this.toggleBtn.addEventListener("click", () => {
        const isOpen = !this.dropdown.hasAttribute("hidden");
        this.dropdown.toggleAttribute("hidden", isOpen);
        this.toggleBtn.setAttribute("aria-expanded", String(!isOpen));
      });

      // Close on outside click
      document.addEventListener("click", (e) => {
        if (!this.contains(e.target as Node)) {
          this.dropdown.setAttribute("hidden", "");
          this.toggleBtn.setAttribute("aria-expanded", "false");
        }
      });

      // Preset buttons
      this.querySelectorAll(".monet-preset-row:not(.monet-custom-row)").forEach((b) => {
        b.addEventListener("click", () => {
          const name = (b as HTMLElement).dataset.name!;
          const label = (b as HTMLElement).dataset.label!;
          this.preset = name;
          this.apply(name, this.variant);
          this.updateActiveUI(name, label);
          localStorage.setItem("monet-preset", name);
        });
      });

      // Custom color picker
      const picker = this.querySelector(".monet-custom-picker") as HTMLInputElement;
      const customRow = this.querySelector(".monet-custom-row") as HTMLElement;
      const customHex = localStorage.getItem("monet-custom-hex");
      if (customHex && picker) {
        picker.value = customHex;
        customRow.style.setProperty("--custom-color-1", customHex);
        customRow.style.setProperty("--custom-color-2", `color-mix(in srgb, ${customHex} 60%, var(--blog-color-tertiary))`);
      }
      
      picker?.addEventListener("input", () => {
        const hex = picker.value;
        customRow.style.setProperty("--custom-color-1", hex);
        customRow.style.setProperty("--custom-color-2", `color-mix(in srgb, ${hex} 60%, var(--blog-color-tertiary))`);
        const key = `custom-${hex.replace("#", "")}-${this.variant}`;
        const { light, dark } = generateSchemeCSS(hex, this.variant);
        const cssStr = light.replace(
          /\[data-monet="[^"]*"\]/,
          `[data-monet="${key}"]`
        ) +
          "\n" +
          dark.replace(
            /\[data-theme="dark"\]\[data-monet="[^"]*"\]/,
            `[data-theme="dark"][data-monet="${key}"]`
          );
        this.inject(cssStr);
        document.documentElement.setAttribute("data-monet", key);
        this.preset = key;
        this.updateActiveUI("custom", "Custom Color", hex);
        localStorage.setItem("monet-preset", key);
        localStorage.setItem("monet-custom-hex", hex);
        localStorage.setItem("monet-custom-css", cssStr);
      });
    }

    private apply(name: string, variant: string) {
      document.documentElement.setAttribute("data-monet", `${name}--${variant}`);
      document.getElementById("monet-custom-inline")?.remove();
    }

    private inject(css: string) {
      let s = document.getElementById("monet-custom-inline") as HTMLStyleElement;
      if (!s) {
        s = document.createElement("style");
        s.id = "monet-custom-inline";
        document.head.appendChild(s);
      }
      s.textContent = css;
    }

    private updateActiveUI(name: string, label: string, customHex?: string) {
      // Update active attributes on rows
      const baseName = name.startsWith("custom-") ? "custom" : name.split("--")[0];
      this.querySelectorAll(".monet-preset-row").forEach((b) => {
        const btn = b as HTMLElement;
        btn.toggleAttribute("data-active", btn.dataset.name === baseName);
      });
    }
  }

  if (!customElements.get("monet-switcher")) {
    customElements.define("monet-switcher", MonetSwitcher);
  }
</script>

