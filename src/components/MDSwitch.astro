---
// MDSwitch.astro — Material Design 3 Switch component

interface Props {
  id?: string;
  checked?: boolean;
  disabled?: boolean;
  name?: string;
  value?: string;
  class?: string;
}

const {
  id = `md-switch-${Math.random().toString(36).substr(2, 9)}`,
  checked = false,
  disabled = false,
  name,
  value,
  class: className = "",
  ...attrs
} = Astro.props;
---

<div class:list={["md-switch-container", { "md-switch--disabled": disabled }, className]}>
  <input
    type="checkbox"
    id={id}
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
    class="md-switch-input"
    {...attrs}
  />
  <label for={id} class="md-switch-track" aria-hidden="true">
    <span class="md-switch-thumb">
      <!-- Checked Icon -->
      <span class="md-switch-icon md-switch-icon--checked">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </span>
      <!-- Unchecked Icon (Optional cross, standard M3 is empty or cross) -->
      <span class="md-switch-icon md-switch-icon--unchecked">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </span>
    </span>
  </label>
</div>

<style>
  .md-switch-container {
    display: inline-flex;
    align-items: center;
    position: relative;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .md-switch-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  /* ── Switch Track ── */
  .md-switch-track {
    position: relative;
    display: inline-block;
    width: var(--switch-track-width);
    height: var(--switch-track-height);
    border-radius: var(--blog-radius-full, 9999px);
    background-color: var(--blog-color-surface-container-highest);
    border: 2px solid var(--blog-color-outline);
    box-sizing: border-box;
    transition: 
      background-color var(--blog-motion-duration-fast, 150ms) var(--blog-motion-easing-standard),
      border-color var(--blog-motion-duration-fast, 150ms) var(--blog-motion-easing-standard);
  }

  /* ── Switch Thumb ── */
  .md-switch-thumb {
    position: absolute;
    top: 50%;
    left: 4px;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--switch-thumb-size);
    height: var(--switch-thumb-size);
    border-radius: 50%;
    background-color: var(--blog-color-outline);
    box-sizing: border-box;
    transition: 
      left var(--blog-motion-duration-normal, 250ms) cubic-bezier(0.2, 0, 0, 1.2), /* custom spring-like effect */
      width var(--blog-motion-duration-fast, 150ms) var(--blog-motion-easing-standard),
      height var(--blog-motion-duration-fast, 150ms) var(--blog-motion-easing-standard),
      background-color var(--blog-motion-duration-fast, 150ms) var(--blog-motion-easing-standard);
  }

  /* Thumb Icon layers */
  .md-switch-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    width: var(--switch-icon-size);
    height: var(--switch-icon-size);
    color: var(--blog-color-primary);
    opacity: 0;
    transform: scale(0.5);
    transition: 
      opacity var(--blog-motion-duration-fast, 150ms) var(--blog-motion-easing-standard),
      transform var(--blog-motion-duration-fast, 150ms) var(--blog-motion-easing-standard);
  }

  .md-switch-icon svg {
    width: 100%;
    height: 100%;
  }

  /* Unchecked custom state (cross) */
  .md-switch-icon--unchecked {
    color: var(--blog-color-surface-container-highest);
  }

  /* ── Selected State ── */
  .md-switch-input:checked + .md-switch-track {
    background-color: var(--blog-color-primary);
    border-color: var(--blog-color-primary);
  }

  .md-switch-input:checked + .md-switch-track .md-switch-thumb {
    left: 24px;
    width: var(--switch-thumb-checked-size);
    height: var(--switch-thumb-checked-size);
    background-color: var(--blog-color-on-primary);
  }

  .md-switch-input:checked + .md-switch-track .md-switch-icon--checked {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Hover and Pressed micro-animations ── */
  .md-switch-container:hover .md-switch-thumb {
    background-color: var(--blog-color-on-surface-variant);
  }

  .md-switch-input:checked:not(:disabled) + .md-switch-track:hover .md-switch-thumb {
    background-color: var(--blog-color-on-primary); /* Keep thumb bright */
  }

  /* Scale thumb slightly on active press (tactile squish) */
  .md-switch-container:active .md-switch-thumb {
    width: var(--switch-thumb-dragging-width);
  }

  /* ── Focus State ── */
  .md-switch-input:focus-visible + .md-switch-track {
    outline: 2px solid var(--blog-color-primary);
    outline-offset: 2px;
  }

  /* ── Disabled State ── */
  .md-switch--disabled {
    pointer-events: none;
    opacity: 0.38;
  }

  .md-switch--disabled .md-switch-track {
    background-color: var(--blog-color-surface-variant);
    border-color: var(--blog-color-outline-variant);
  }

  .md-switch--disabled .md-switch-thumb {
    background-color: var(--blog-color-outline-variant);
  }
</style>
