---
// SearchBar.astro — Material Design 3 Pill-shaped Search Bar Component

interface Props {
  id?: string;
  placeholder?: string;
  class?: string;
  [key: string]: any;
}

const {
  id = "search-input",
  placeholder = "Search...",
  class: className = "",
  ...attrs
} = Astro.props;
---

<div class:list={["md-search-bar", className]} {...attrs}>
  <div class="md-search-bar__leading">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
  </div>
  <input
    type="text"
    id={id}
    class="md-search-bar__input"
    placeholder={placeholder}
    autocomplete="off"
  />
  <button
    type="button"
    class="md-search-bar__clear"
    id={`${id}-clear`}
    aria-label="Clear search"
    style="display: none;"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
</div>

<style>
  /* Material Design 3 Pill Search Bar */
  .md-search-bar {
    display: flex;
    align-items: center;
    position: relative;
    width: 100%;
    height: 48px;
    padding: 0 16px;
    border-radius: var(--blog-radius-full, 9999px);
    background-color: var(--blog-color-surface-container-high);
    border: 1px solid var(--blog-color-outline-variant);
    box-sizing: border-box;
    transition: 
      background-color var(--blog-motion-duration-fast) var(--blog-motion-easing-standard),
      box-shadow var(--blog-motion-duration-fast) var(--blog-motion-easing-standard),
      border-color var(--blog-motion-duration-fast) var(--blog-motion-easing-standard);
  }

  .md-search-bar:hover {
    background-color: var(--blog-color-surface-container-highest);
    border-color: var(--blog-color-outline);
  }

  .md-search-bar:focus-within {
    background-color: var(--blog-color-surface);
    border-color: var(--blog-color-primary);
    box-shadow: var(--blog-elevation-1);
  }

  .md-search-bar__leading {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blog-color-on-surface-variant);
    margin-right: 12px;
    flex-shrink: 0;
    transition: color var(--blog-motion-duration-fast);
  }

  .md-search-bar:focus-within .md-search-bar__leading {
    color: var(--blog-color-primary);
  }

  .md-search-bar__input {
    flex: 1;
    height: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--blog-font-sans);
    font-size: var(--blog-typescale-body-large-size);
    font-weight: var(--blog-font-weight-regular);
    color: var(--blog-color-on-surface);
    padding: 0;
  }

  .md-search-bar__input::placeholder {
    color: var(--blog-color-text-secondary);
    opacity: 0.8;
  }

  .md-search-bar__clear {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--blog-color-on-surface-variant);
    cursor: pointer;
    margin-left: 8px;
    flex-shrink: 0;
    transition: 
      background-color var(--blog-motion-duration-fast),
      color var(--blog-motion-duration-fast);
  }

  .md-search-bar__clear:hover {
    background-color: var(--blog-color-surface-container-highest);
    color: var(--blog-color-on-surface);
  }
</style>

<script>
  function initSearchBars() {
    document.querySelectorAll(".md-search-bar").forEach((bar) => {
      const input = bar.querySelector(".md-search-bar__input") as HTMLInputElement;
      const clearBtn = bar.querySelector(".md-search-bar__clear") as HTMLButtonElement;

      if (!input || !clearBtn) return;

      const toggleClearBtn = () => {
        clearBtn.style.display = input.value.trim() ? "flex" : "none";
      };

      // Toggle on load and keystroke
      toggleClearBtn();
      input.addEventListener("input", toggleClearBtn);

      // Handle query clearing
      clearBtn.addEventListener("click", () => {
        input.value = "";
        toggleClearBtn();
        input.focus();
        
        // Dispatch input event so list filter listener triggers automatically
        input.dispatchEvent(new Event("input", { bubbles: true }));
      });
    });
  }

  // Handle initialization
  initSearchBars();
  document.addEventListener("astro:after-swap", initSearchBars);
</script>
