---
// Backlinks.astro — Displays incoming links (backlinks) to the current page
import { getCollection } from "astro:content";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

// Normalise the current slug (strip file extension if present)
const cleanCurrentSlug = currentSlug.replace(/\.mdx?$/, "");

// Load all non-draft posts
const allPosts = await getCollection("blog", ({ data }) => !data.draft);

// Scan all posts' bodies for [[WikiLink]] syntax pointing to the current post
const backlinks = allPosts
  .filter((post) => {
    const cleanPostId = post.id.replace(/\.mdx?$/, "");
    if (cleanPostId === cleanCurrentSlug) return false; // Skip self

    const body = post.body || "";
    // Match [[slug]] or [[slug|alias]]
    const wikiLinkRegex = /\[\[([a-zA-Z0-9\-_#]+)(?:\|[^\]]+)?\]\]/g;
    let match;

    while ((match = wikiLinkRegex.exec(body)) !== null) {
      const targetSlug = match[1].replace(/\.mdx?$/, "");
      if (targetSlug === cleanCurrentSlug) {
        return true;
      }
    }
    return false;
  })
  .map((post) => ({
    slug: post.id.replace(/\.mdx?$/, ""),
    title: post.data.title,
    description: post.data.description,
    growthStage: post.data.growthStage,
  }));

const hasBacklinks = backlinks.length > 0;

// Mapping stages to emojis and names
const STAGE_MAP = {
  seedling: { emoji: "🌱", label: "Seedling" },
  budding: { emoji: "🌿", label: "Budding" },
  evergreen: { emoji: "🌳", label: "Evergreen" },
};
---

{
  hasBacklinks && (
    <div class="backlinks-section">
      <h3 class="backlinks-title text-title-large">
        <span class="backlinks-title-dot"></span>
        Connections & Backlinks
      </h3>
      <div class="backlinks-grid">
        {backlinks.map((link) => {
          const stage = STAGE_MAP[link.growthStage || "seedling"];
          return (
            <article class="backlink-card">
              <a href={`/blog/${link.slug}`} class="backlink-link">
                <div class="backlink-header">
                  <span class={`backlink-stage-badge backlink-stage--${link.growthStage}`} title={`Growth stage: ${stage.label}`}>
                    <span class="badge-emoji">{stage.emoji}</span>
                    <span class="badge-text">{stage.label}</span>
                  </span>
                </div>
                <h4 class="backlink-card-title text-title-medium">{link.title}</h4>
                <p class="backlink-card-desc text-body-medium text-secondary">{link.description}</p>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  )
}


