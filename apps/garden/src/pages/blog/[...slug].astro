---
// blog/[...slug].astro — Individual blog post page
import { getCollection, type CollectionEntry } from "astro:content";
import BlogPostLayout from "@m3e/layouts/BlogPostLayout.astro";
import { siteConfig } from "../../config/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => {
    const slug = post.id.replace(/\.mdx?$/, "");
    
    // Calculate backlinks referencing this post
    const backlinks = posts
      .filter((otherPost) => {
        const cleanOtherPostId = otherPost.id.replace(/\.mdx?$/, "");
        if (cleanOtherPostId === slug) return false; // Skip self

        const body = otherPost.body || "";
        const wikiLinkRegex = /\[\[([a-zA-Z0-9\-_#]+)(?:\|[^\]]+)?\]\]/g;
        let match;

        while ((match = wikiLinkRegex.exec(body)) !== null) {
          const targetSlug = match[1].replace(/\.mdx?$/, "");
          if (targetSlug === slug) {
            return true;
          }
        }
        return false;
      })
      .map((otherPost) => ({
        slug: otherPost.id.replace(/\.mdx?$/, ""),
        title: otherPost.data.title,
        description: otherPost.data.description,
        growthStage: otherPost.data.growthStage,
      }));

    return {
      params: { slug },
      props: { post, backlinks },
    };
  });
}

interface Props {
  post: CollectionEntry<"blog">;
  backlinks: Array<{ slug: string; title: string; description: string; growthStage: any }>;
}

const { post, backlinks } = Astro.props;
const { Content, headings } = await post.render();
---

<BlogPostLayout 
  post={post} 
  headings={headings} 
  backlinks={backlinks}
  siteName={siteConfig.name}
  siteCopyright={siteConfig.copyright}
  musicMode={siteConfig.music?.mode}
  musicApiEndpoint={siteConfig.music?.mode === 'api' ? `${siteConfig.music.metingApi}?server=${siteConfig.music.server}&type=playlist&id=${siteConfig.music.playlistId}` : ''}
>
  <Content />
</BlogPostLayout>
