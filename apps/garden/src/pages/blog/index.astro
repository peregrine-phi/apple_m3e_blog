---
// blog/index.astro — Blog post listing with dynamic tag & search filtering
import BlogListLayout from "@m3e/layouts/BlogListLayout.astro";
import BlogCard from "@m3e/components/BlogCard.astro";
import SearchBar from "@m3e/components/SearchBar.astro";
import I18n from "@m3e/components/I18n.astro";
import FilterGroup from "@m3e/components/FilterGroup.astro";
import MDSwitch from "@m3e/components/MDSwitch.astro";
import { tagConfig, stageConfig } from "@m3e/config/filter-config";
import { getCollection } from "astro:content";
import { siteConfig } from "../../config/site";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// Get unique tags from all posts
const allTags = Array.from(new Set(posts.flatMap(p => p.data.tags || []))).sort();
---

<script is:inline>
  (function(){
    var showAll = localStorage.getItem("blog-show-all-langs") === "true";
    if (showAll) {
      document.documentElement.setAttribute("data-show-all-langs", "true");
    }
  })();
</script>

<BlogListLayout
  title={`Blog — ${siteConfig.name}`}
  description={siteConfig.description}
  siteName={siteConfig.name}
  siteCopyright={siteConfig.copyright}
  musicMode={siteConfig.music?.mode}
  musicApiEndpoint={siteConfig.music?.mode === 'api' ? `${siteConfig.music.metingApi}?server=${siteConfig.music.server}&type=playlist&id=${siteConfig.music.playlistId}` : ''}
>
  {
    posts.length === 0 ? (
      <div class="empty-state">
        <p class="text-body-large text-secondary"><I18n tKey="blog.empty" /></p>
      </div>
    ) : (
      <div class="blog-filter-section">
        <div class="search-and-toggle-container" style="display: flex; gap: var(--blog-space-4); align-items: center; justify-content: space-between; flex-wrap: wrap; width: 100%;">
          <div class="search-container">
            <SearchBar id="blog-search" placeholder="Search articles, tags or descriptions..." />
          </div>
          <div class="show-all-langs-toggle-container" style="display: flex; align-items: center; gap: var(--blog-space-2-5); flex-shrink: 0; padding-block: 4px;">
            <span class="text-label-medium text-secondary">
              <span class="i18n-en">Show All Languages</span>
              <span class="i18n-zh">显示所有语种文章</span>
            </span>
            <MDSwitch id="show-all-langs-toggle" />
          </div>
        </div>

        <!-- Reusable Filter Layout Group: Tags -->
        <FilterGroup
          titleKey="blog.filterTag"
          badgeVariant="primary"
          filterType="tag"
          items={allTags}
          config={tagConfig}
          allLabelKey="blog.allTags"
        />

        <!-- Reusable Filter Layout Group: Stages -->
        <FilterGroup
          titleKey="blog.filterStage"
          badgeVariant="secondary"
          filterType="stage"
          items={["seedling", "budding", "evergreen"]}
          config={stageConfig}
          allLabelKey="blog.allStages"
        />
      </div>

      <div class="blog-grid">
        {posts.map((post) => (
          <div 
            class="blog-card-wrapper" 
            data-tags={post.data.tags?.map(t => t.toLowerCase()).join(",") || ""}
            data-title={post.data.title.toLowerCase()}
            data-desc={post.data.description.toLowerCase()}
            data-stage={post.data.growthStage}
            data-lang={post.data.lang}
          >
            <BlogCard post={post} />
          </div>
        ))}
      </div>
    )
  }
</BlogListLayout>


<script>
  function initFilters() {
    const searchInput = document.getElementById("blog-search") as HTMLInputElement;
    if (!searchInput) return;

    const tagChips = document.querySelectorAll(".tags-chips .filter-chip");
    const allTagChip = document.querySelector('.tags-chips .filter-chip[data-tag="all"]');
    const stageChips = document.querySelectorAll(".stages-chips .filter-chip");
    const allStageChip = document.querySelector('.stages-chips .filter-chip[data-stage="all"]');
    const cards = document.querySelectorAll(".blog-card-wrapper") as NodeListOf<HTMLElement>;

    let activeTags = new Set<string>();
    let activeStages = new Set<string>();
    let searchQuery = "";

    function updatePlaceholder(lang: string) {
      if (searchInput) {
        searchInput.placeholder = lang === "zh" ? "搜索文章、标签或描述..." : "Search articles, tags or descriptions...";
      }
    }

    // Set initial placeholder based on current lang
    const initialLang = document.documentElement.getAttribute("lang") || "en";
    updatePlaceholder(initialLang);

    // Listen to client-side language changes
    window.addEventListener("lang-change", (e: any) => {
      updatePlaceholder(e.detail.lang);
      // Re-trigger filter in case empty state text needs localization change
      filterPosts();
    });

    const showAllLangsToggle = document.getElementById("show-all-langs-toggle") as HTMLInputElement;

    // Restore saved toggle state from memory
    if (showAllLangsToggle) {
      const savedShowAll = localStorage.getItem("blog-show-all-langs") === "true";
      showAllLangsToggle.checked = savedShowAll;
      document.documentElement.setAttribute("data-show-all-langs", savedShowAll ? "true" : "false");
    }

    function filterPosts() {
      // 1. FIRST: Record the position of all currently visible cards before layout changes
      const firstPositions = new Map<HTMLElement, { top: number; left: number }>();
      cards.forEach((card) => {
        if (card.style.display !== "none") {
          const rect = card.getBoundingClientRect();
          firstPositions.set(card, { top: rect.top, left: rect.left });
        }
      });

      let visibleCount = 0;
      const showAllLangs = showAllLangsToggle?.checked || false;

      // 2. Update visibility immediately to trigger browser layout calculation (reflow)
      cards.forEach((card) => {
        const tagsStr = card.dataset.tags || "";
        const title = card.dataset.title || "";
        const desc = card.dataset.desc || "";
        const stage = card.dataset.stage || "seedling";
        const cardLang = card.dataset.lang || "en";

        const currentLang = document.documentElement.getAttribute("lang") || "en";
        const matchesLang = showAllLangs || (cardLang === currentLang);

        const cardTags = tagsStr.split(",").filter(Boolean);
        const matchesTag = activeTags.size === 0 || cardTags.some(t => activeTags.has(t));
        const matchesStage = activeStages.size === 0 || activeStages.has(stage);
        const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery) || tagsStr.includes(searchQuery);

        const shouldShow = matchesLang && matchesTag && matchesStage && matchesSearch;

        if (shouldShow) {
          if (card.style.display === "none") {
            card.style.display = "";
            card.style.opacity = "0";
            card.style.transform = "scale(0.96) translateY(12px)";
          } else if (!card.style.display) {
            // Already visible; keep standard opacity/transform to prevent blank first paints
            card.style.display = "";
            card.style.opacity = "1";
            card.style.transform = "";
          }
          visibleCount++;
        } else {
          card.style.display = "none";
        }
      });

      // 3. LAST & INVERT & PLAY: Animate shifting cards to their new positions
      requestAnimationFrame(() => {
        cards.forEach((card) => {
          if (card.style.display !== "none") {
            const firstPos = firstPositions.get(card);
            
            if (firstPos) {
              // Card was already visible; calculate layout shift
              const lastRect = card.getBoundingClientRect();
              const dx = firstPos.left - lastRect.left;
              const dy = firstPos.top - lastRect.top;

              if (dx !== 0 || dy !== 0) {
                // INVERT: Instantly translate it back to its original layout position
                card.style.transition = "none";
                card.style.transform = `translate(${dx}px, ${dy}px)`;
                
                // PLAY: Transition it back to its new position smoothly in the next frame
                requestAnimationFrame(() => {
                  card.style.transition = "transform 350ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 350ms cubic-bezier(0.2, 0.8, 0.2, 1)";
                  card.style.transform = "";
                  card.style.opacity = "1";
                });
              } else {
                // No shift; ensure standard state
                card.style.transition = "transform 350ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 350ms cubic-bezier(0.2, 0.8, 0.2, 1)";
                card.style.opacity = "1";
                card.style.transform = "";
              }
            } else {
              // New Card entering: Fade in and scale up smoothly
              requestAnimationFrame(() => {
                card.style.transition = "transform 350ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 350ms cubic-bezier(0.2, 0.8, 0.2, 1)";
                card.style.opacity = "1";
                card.style.transform = "";
              });
            }
          }
        });
      });

      // Handle empty state
      let emptyEl = document.getElementById("blog-empty-state");
      if (visibleCount === 0) {
        if (!emptyEl) {
          emptyEl = document.createElement("div");
          emptyEl.id = "blog-empty-state";
          emptyEl.className = "empty-state";
          const grid = document.querySelector(".blog-grid");
          grid?.parentNode?.appendChild(emptyEl);
        }
        const isZh = document.documentElement.getAttribute("lang") === "zh";
        emptyEl.innerHTML = `<p class="text-body-large text-secondary">${
          isZh ? "没有找到匹配您搜索的文章。" : "No articles found matching your search."
        }</p>`;
      } else {
        emptyEl?.remove();
      }
    }

    tagChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const tag = (chip as HTMLElement).dataset.tag || "all";
        
        if (tag === "all") {
          activeTags.clear();
          tagChips.forEach((c) => c.classList.remove("active"));
          allTagChip?.classList.add("active");
        } else {
          allTagChip?.classList.remove("active");
          
          if (activeTags.has(tag)) {
            activeTags.delete(tag);
            chip.classList.remove("active");
          } else {
            activeTags.add(tag);
            chip.classList.add("active");
          }
          
          if (activeTags.size === 0) {
            allTagChip?.classList.add("active");
          }
        }
        
        filterPosts();
      });
    });

    stageChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const stage = (chip as HTMLElement).dataset.stage || "all";
        
        if (stage === "all") {
          activeStages.clear();
          stageChips.forEach((c) => c.classList.remove("active"));
          allStageChip?.classList.add("active");
        } else {
          allStageChip?.classList.remove("active");
          
          if (activeStages.has(stage)) {
            activeStages.delete(stage);
            chip.classList.remove("active");
          } else {
            activeStages.add(stage);
            chip.classList.add("active");
          }
          
          if (activeStages.size === 0) {
            allStageChip?.classList.add("active");
          }
        }
        
        filterPosts();
      });
    });

    searchInput?.addEventListener("input", () => {
      searchQuery = searchInput.value.toLowerCase().trim();
      filterPosts();
    });

    showAllLangsToggle?.addEventListener("change", () => {
      const checked = showAllLangsToggle.checked;
      localStorage.setItem("blog-show-all-langs", checked ? "true" : "false");
      document.documentElement.setAttribute("data-show-all-langs", checked ? "true" : "false");
      filterPosts();
    });

    // Run initial filter to align grid with the current page language
    filterPosts();
  }

  document.addEventListener("astro:page-load", initFilters);
</script>
