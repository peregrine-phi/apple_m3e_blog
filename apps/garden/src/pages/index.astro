---
// index.astro — Home page entry point
// Delegates rendering to HomePage component in @m3e/framework
import HomePage from "@m3e/pages/HomePage.astro";
import { getCollection } from "astro:content";
import { siteConfig, getMusicApiEndpoint } from "../config/site";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const featuredPosts = posts
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const recentPosts = posts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 6);
---

<HomePage
  siteName={siteConfig.name}
  siteTagline={siteConfig.tagline}
  siteDescription={siteConfig.description}
  siteCopyright={siteConfig.copyright}
  musicMode={siteConfig.music?.mode}
  musicApiEndpoint={getMusicApiEndpoint()}
  featuredPosts={featuredPosts}
  recentPosts={recentPosts}
/>
