---
// about.astro — About page entry point
// Delegates rendering to AboutPage component in @m3e/framework
import AboutPage from "@m3e/pages/AboutPage.astro";
import { getEntry } from "astro:content";
import { siteConfig, getMusicApiEndpoint } from "../config/site";

const enBio = await getEntry("about", "en");
const zhBio = await getEntry("about", "zh");

const { Content: EnContent } = enBio ? await enBio.render() : { Content: null };
const { Content: ZhContent } = zhBio ? await zhBio.render() : { Content: null };
---

<AboutPage
  siteName={siteConfig.name}
  siteDescription={siteConfig.description}
  siteCopyright={siteConfig.copyright}
  musicMode={siteConfig.music?.mode}
  musicApiEndpoint={getMusicApiEndpoint()}
  enContent={EnContent}
  zhContent={ZhContent}
/>
